# Desktop Teacher 环境配置模板
# 复制此文件为 .env 并填入真实值

# ---- LLM Provider 配置 ----

# 默认使用的 provider: "openai" 或 "qwen"
VITE_LLM_DEFAULT_PROVIDER=openai

# OpenAI
VITE_OPENAI_API_KEY=sk-your-openai-key
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_OPENAI_MODEL=gpt-4o

# Qwen / DashScope
VITE_QWEN_API_KEY=sk-your-dashscope-key
VITE_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VITE_QWEN_MODEL=qwen-plus

# ---- 应用配置 ----

# 全局截图快捷键
VITE_HOTKEY_SCREENSHOT=Ctrl+Shift+S
